generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id              String   @id @default(uuid())
  nome            String
  email           String   @unique
  senha           String
  papel           String  
  
  // Novos atributos alinhados com o documento de requisitos
  telefone        String?
  foto_perfil_url String?
  latitude_atual  Float?
  longitude_atual Float?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  cuidadores      Vinculo_Cuidado[] @relation("Paciente")
  pacientes       Vinculo_Cuidado[] @relation("Cuidador")
}

model Vinculo_Cuidado {
  id           String   @id @default(uuid())
  pacienteId   String
  cuidadorId   String
  status       String   @default("PENDENTE") // Pode ser: PENDENTE, ACEITO, RECUSADO
  
  // Novo atributo alinhado com o documento de requisitos
  nivel_acesso String?  @default("TOTAL") // Ex: TOTAL, LEITURA

  paciente     Usuario  @relation("Paciente", fields: [pacienteId], references: [id])
  cuidador     Usuario  @relation("Cuidador", fields: [cuidadorId], references: [id])

  createdAt    DateTime @default(now())

  //Evita que o mesmo cuidador crie dois vínculos com o mesmo paciente
  @@unique([pacienteId, cuidadorId]) 
}